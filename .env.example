# ============================================================
# Deenx AI — Environment Variables
# Copy to backend/.env (and frontend/.env.local for NEXT_PUBLIC_*).
# Never commit real values. Nothing in the codebase is hardcoded.
# ============================================================

# ---------- Application ----------
ENVIRONMENT=development              # development | staging | production
DEBUG=true                            # MUST be false in production

# ---------- PostgreSQL (Neon Cloud) ----------
# Neon dashboard -> Connection Details -> pooled connection string
DATABASE_URL=postgresql+asyncpg://USER:PASSWORD@HOST/DBNAME?ssl=require
DATABASE_URL_SYNC=postgresql+psycopg://USER:PASSWORD@HOST/DBNAME?sslmode=require
DB_POOL_SIZE=10
DB_MAX_OVERFLOW=5
DB_POOL_RECYCLE=300

# ---------- Redis ----------
REDIS_URL=redis://localhost:6379/0
CELERY_BROKER_URL=redis://localhost:6379/1
CELERY_RESULT_BACKEND=redis://localhost:6379/2

# ---------- JWT ----------
# Generate each with: openssl rand -hex 64
JWT_SECRET_KEY=
JWT_REFRESH_SECRET_KEY=
JWT_ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=30
REFRESH_TOKEN_EXPIRE_DAYS=30

# ---------- Field encryption ----------
# Generate with:
# python -c "from cryptography.fernet import Fernet; print(Fernet.generate_key().decode())"
FIELD_ENCRYPTION_KEY=

# ---------- Meta / WhatsApp Cloud API (platform-level, set ONCE) ----------
META_APP_ID=
META_APP_SECRET=
META_SYSTEM_USER_TOKEN=
META_VERIFY_TOKEN=

# Phase 7 — campaign send pacing (messages per second). Keep low for
# Cloud API's default throughput tier; raise once your number is
# verified at a higher tier in Meta Business Manager.
CAMPAIGN_SEND_RATE_PER_SECOND=1
META_EMBEDDED_SIGNUP_CONFIG_ID=
META_GRAPH_API_VERSION=v21.0

# ---------- AI ----------
OPENAI_API_KEY=
ANTHROPIC_API_KEY=
AI_DEFAULT_PROVIDER=openai

# ---------- Email (SMTP) ----------
SMTP_HOST=
SMTP_PORT=587
SMTP_USERNAME=
SMTP_PASSWORD=
FROM_EMAIL=

# ---------- CORS / URLs ----------
FRONTEND_URL=http://localhost:3000
BACKEND_URL=http://localhost:8000
DOMAIN_NAME=

# ============================================================
# Frontend (Next.js) — put these in frontend/.env.local
# Only NEXT_PUBLIC_* vars are exposed to the browser; never put
# secrets here.
# ============================================================
NEXT_PUBLIC_API_URL=http://localhost:8000/api/v1
NEXT_PUBLIC_WS_URL=ws://localhost:8000/api/v1/ws
