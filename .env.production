# Application
APP_NAME=Limbu WA SaaS
ENVIRONMENT=production
DEBUG=false

# Database (Docker PostgreSQL)
POSTGRES_DB=limbu_prod
POSTGRES_USER=limbu_user
POSTGRES_PASSWORD=CHANGE_THIS_DB_PASSWORD

DATABASE_URL=postgresql+asyncpg://limbu_user:CHANGE_THIS_DB_PASSWORD@postgres:5432/limbu_prod
DATABASE_URL_SYNC=postgresql+psycopg://limbu_user:CHANGE_THIS_DB_PASSWORD@postgres:5432/limbu_prod

DB_POOL_SIZE=10
DB_MAX_OVERFLOW=5
DB_POOL_RECYCLE=300

# Redis
REDIS_PASSWORD=CHANGE_THIS_REDIS_PASSWORD
REDIS_URL=redis://:CHANGE_THIS_REDIS_PASSWORD@redis:6379/0
CELERY_BROKER_URL=redis://:CHANGE_THIS_REDIS_PASSWORD@redis:6379/1
CELERY_RESULT_BACKEND=redis://:CHANGE_THIS_REDIS_PASSWORD@redis:6379/2

# JWT
JWT_SECRET_KEY=CHANGE_THIS_64_CHAR_KEY
JWT_REFRESH_SECRET_KEY=CHANGE_THIS_DIFFERENT_64_CHAR_KEY
JWT_ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=30
REFRESH_TOKEN_EXPIRE_DAYS=30

# Encryption
FIELD_ENCRYPTION_KEY=CHANGE_THIS_FERNET_KEY

# Meta / WhatsApp
META_APP_ID=your_meta_app_id
META_APP_SECRET=your_meta_app_secret
META_VERIFY_TOKEN=your_webhook_verify_token
META_GRAPH_API_VERSION=v21.0
CAMPAIGN_SEND_RATE_PER_SECOND=1

# Email
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USERNAME=digitalsynk360@gmail.com
SMTP_PASSWORD=your_google_app_password
FROM_EMAIL=digitalsynk360@gmail.com
FROM_NAME=Limbu WA SaaS

# Domain — APNA DOMAIN YAHAN DAALO
APP_URL=https://app.deenxconsultancy.com
FRONTEND_URL=https://app.deenxconsultancy.com
BACKEND_URL=https://api.deenxconsultancy.com
DOMAIN_NAME=deenxconsultancy.com
NEXT_PUBLIC_API_URL=https://api.deenxconsultancy.com/api/v1
NEXT_PUBLIC_WS_URL=wss://api.deenxconsultancy.com

# AI (Optional)
OPENAI_API_KEY=
ANTHROPIC_API_KEY=
AI_DEFAULT_PROVIDER=openai